            { "name": "None (All Articles)", "value": "" },
            { "name": "By Tag", "value": "tags" },
            { "name": "By Category (Current Page)", "value": "category" },
            { "name": "By Specific Paths", "value": "paths" }
          ]
        },
        {
          "component": "text",
